# This is an example environment file.
# Copy this file to .env.dev or .env.prod and fill in the actual values.

# PostgreSQL Database Configuration
POSTGRE_DB_USERNAME=your_postgres_username
POSTGRE_DB_PASSWORD=your_postgres_password
POSTGRE_DB_HOST=your_postgres_host
POSTGRE_DB_PORT=5432

# MongoDB Database Configuration
MONGO_DB_USERNAME=your_mongo_username
MONGO_DB_PASSWORD=your_mongo_password
MONGO_DB_HOST=your_mongo_host
MONGO_DB_NAME=your_mongo_db_name
MONGO_URI=your_mongo_uri

# JWT Secret for token signing
JWT_SECRET=a_very_strong_and_long_secret_key_that_is_hard_to_guess

# Google Cloud Platform Configuration
GOOGLE_PROJECT_ID=your_gcp_project_id
GCP_CREDENTIALS_BASE64=your_base64_encoded_gcp_credentials_json

# Cloudinary Configuration for media storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google OAuth Client ID for social login
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Redis Configuration for caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Email Configuration for sending emails
RESEND_FROM_DOMAIN=your_resend_domain
RESEND_FROM_NAME=your_resend_app_name
RESEND_API_KEY=your_resend_api_key

